# Copy to .env and fill in. Never commit the real .env (see .gitignore).

# --- Home Assistant ----------------------------------------------------------
# Base URL of your Home Assistant instance.
HA_URL=http://homeassistant.local:8123
# Long-lived access token (HA -> your profile -> Security -> Long-lived tokens).
HA_TOKEN=replace_me
# The notify service for your phone, e.g. notify.mobile_app_pixel_10.
NOTIFY_SERVICE=notify.mobile_app_your_phone

# --- Trusted senders ---------------------------------------------------------
# JSON object mapping sender number -> {name, list}. Only these senders are
# classified; everyone else is ignored. Add people here, not in code.
TRUSTED_SENDERS={"441234567890": {"name": "Partner", "list": "todo.tasks_inbox"}}

# --- Local models (Ollama) ---------------------------------------------------
# Chat model for classification. Any Ollama host with the model pulled.
OLLAMA_CHAT_URL=http://localhost:11434
CLASSIFIER_MODEL=qwen3:32b
# Embedding endpoint for de-duplication. MUST be an Ollama that has the embed
# model pulled — a chat-only server 404s /api/embeddings. Can be the same host.
OLLAMA_EMBED_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
# Cosine-similarity threshold above which a new task counts as a duplicate.
DEDUP_THRESHOLD=0.85

# --- Paths / behaviour (optional; sensible defaults) -------------------------
# TASK_LOG_PATH=~/task_pipeline.log
# TASK_STATE_PATH=~/task_pipeline_state.json
# REMINDER_CLICK_PATH=/tasks
