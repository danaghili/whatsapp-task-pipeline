# Copy to .env and fill in. Never commit the real .env (see .gitignore).
# After filling it in, run `wtp-check` — it prints a green/red line per
# setting and names exactly what to fix.

# --- Home Assistant ----------------------------------------------------------
# Base URL of your Home Assistant instance. An address, not a secret.
HA_URL=http://homeassistant.local:8123
# SECRET — long-lived access token. Create it in Home Assistant: your profile
# -> Security -> Long-lived access tokens. Paste the value here and nowhere
# else; it is never logged and never leaves your machine except to HA itself.
HA_TOKEN=replace_me
# The notify service for your phone (needs the HA Companion app). Find yours:
# Developer tools -> Actions -> search "notify.mobile_app".
NOTIFY_SERVICE=notify.mobile_app_your_phone

# --- Trusted senders ---------------------------------------------------------
# JSON object mapping sender number -> {name, list}. Only these senders are
# classified; everyone else is ignored. Add people here, not in code.
# The numbers stay in this local file; they are never sent to any AI.
TRUSTED_SENDERS={"441234567890": {"name": "Partner", "list": "todo.tasks_inbox"}}

# --- Message source ----------------------------------------------------------
# The Home Assistant event your WhatsApp integration fires for each incoming
# message. Integrations differ — check your integration's docs (README step 1)
# and set this to match. The default fits bridges that fire
# whatsapp_message_received.
# MESSAGE_EVENT=whatsapp_message_received

# --- AI endpoints (the universal, OpenAI-style format) -----------------------
# Every AI provider is configured the same way: a base URL, an optional API
# key, and a model name. Local servers (Ollama, LM Studio, llama.cpp) and
# cloud providers (OpenAI, OpenRouter, ...) all speak this format.
# NOTE for Ollama: the URL must end in /v1 (its OpenAI-compatible surface).

# Chat model — does the "is this a task?" classification.
CHAT_BASE_URL=http://localhost:11434/v1
CHAT_MODEL=qwen3:32b
# SECRET — only needed for providers that require a key (cloud). Leave empty
# for a local Ollama. Never logged, never committed.
CHAT_API_KEY=

# Provider-specific tuning, merged into the chat request as-is (JSON object).
# For Ollama, turning "think" mode off measurably helps small local models on
# this short structured task. Leave unset for cloud providers.
CHAT_EXTRA_BODY={"think": false}

# Embeddings — powers the "don't add the same task twice" check. Configured
# separately from chat: you can keep this on a small local model even when
# chat is in the cloud. If this endpoint is unset or unreachable the
# duplicate check simply switches off — tasks are never dropped.
# MUST be a server that actually has an embedding model (a chat-only server
# answers 404 here — wtp-check catches this).
EMBED_BASE_URL=http://localhost:11434/v1
EMBED_MODEL=nomic-embed-text
EMBED_API_KEY=

# Similarity above which a new task counts as a duplicate of an open one.
# 0.80 catches re-phrasings of the same ask; raise toward 0.85 if genuinely
# different tasks ever get skipped as duplicates.
DEDUP_THRESHOLD=0.80

# --- Privacy -----------------------------------------------------------------
# The tool is local-first: with the default endpoints above, no message text
# ever leaves your network. If you point CHAT_BASE_URL (or EMBED_BASE_URL) at
# a cloud provider, the tool REFUSES TO START until you set this switch —
# a one-time, deliberate acknowledgment that your household's real message
# text will be sent to that provider. The sender's name is stripped and the
# number is never sent, but the words themselves do go. This is a knowing
# exception to the tool's own privacy promise. See README: "Using a cloud
# provider".
# ACCEPT_CLOUD_TEXT=yes

# Logs record the application flow and errors only — never message or task
# wording — so a shared log can't leak your household's words. Set this while
# debugging your own setup to include full content.
# LOG_VERBOSE=true

# --- Paths / behaviour (optional; sensible defaults) -------------------------
# TASK_LOG_PATH=~/task_pipeline.log
# TASK_STATE_PATH=~/task_pipeline_state.json
# REMINDER_CLICK_PATH=/tasks
