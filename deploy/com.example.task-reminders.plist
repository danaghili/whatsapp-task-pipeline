<?xml version="1.0" encoding="UTF-8"?>
<!--
  launchd agent that runs the reminder cycle every 30 minutes (macOS).
  The script self-gates to waking hours, so firing unconditionally is fine.

  Install:
    1. Edit the two paths below: your .env location and the wtp-remind
       command from the virtualenv you installed the tool into
       (e.g. $HOME/whatsapp-task-pipeline/.venv/bin/wtp-remind).
    2. cp deploy/com.example.task-reminders.plist ~/Library/LaunchAgents/
    3. launchctl load ~/Library/LaunchAgents/com.example.task-reminders.plist

  RunAtLoad is false on purpose: a reboot shouldn't fire a spurious reminder the
  moment the machine comes back (possibly in the middle of the night).

  On Linux, use a systemd timer or cron instead — or skip this entirely and use
  docker compose, whose reminders service runs the same 30-minute cycle.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.example.task-reminders</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-lc</string>
        <string>set -a; source $HOME/path/to/.env; set +a; exec $HOME/path/to/.venv/bin/wtp-remind</string>
    </array>

    <key>StartInterval</key>
    <integer>1800</integer>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/tmp/task-reminders.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/task-reminders.stderr.log</string>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
